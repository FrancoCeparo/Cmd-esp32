#include <Arduino.h>
#include <stdbool.h>
#include <string.h>
/**
 * @brief Pin del esp32 utilizado para controlar el LED.
 */
#define LED_PIN 2

typedef int (*pAction)(int, char **);

/**
 * @brief Estructura que representa un comando del intérprete.
 */
typedef struct {
   /**
     * @brief Función asociada al comando.
     */ 
    pAction act;
     /**
     * @brief Palabra clave del comando.
     */
    const char *keyWord;
    /**
     * @brief Descripción del comando.
     */
    const char *help;
} cmd;

/**
 * @brief Indica si la aplicación debe finalizar.
 */
bool appClose = false;

int multi(int argc, char * argv[]);
int sumar(int argc, char * argv[]);
int restar(int argc, char * argv[]);
int exitCmd(int argc, char * argv[]);
int help(int argc, char * argv[]);

int ledOn(int argc,char *argv[]);
int ledOff(int argc,char *argv[]);
int led(int argc,char *argv[]);
int blink(int argc,char *argv[]);

/**
 * @brief Tabla de comandos disponibles.
 *
 * Cada entrada contiene:
 * - Función a ejecutar.
 * - Palabra clave del comando.
 * - Descripción de ayuda.
 */
static cmd commands [] = {
    {multi, "multi", "multiplica 2 valores"},
    {sumar, "sumar", "Suma dos valores dados como argumentos de línea de órdenes"},
    {restar, "restar", "Resta dos valores dados como argumentos de línea de órdenes"},
    {exitCmd, "exit", "Finaliza el intérprete de comandos"},
    {help, "help", "Brinda información sobre los comandos disponibles"},
    {ledOn,"ledOn","Enciende LED"},
    {ledOff,"ledOff","Apaga LED"},
    {led,"led","led on/off"},
    {blink,"blink","Parpadea 3 veces"},
    {NULL, NULL, NULL}
};

/**
 * @brief Inicializa el sistema.
 *
 * Configura la comunicación serie a 115200 baudios
 * y establece el pin asociado al LED como salida digital.
 * Además, muestra el mensaje de bienvenida del intérprete.
 */
void setup()
{
    Serial.begin(115200);
    pinMode(LED_PIN, OUTPUT);

    Serial.println("CLI iniciado");
    Serial.print("[*]> ");
}

/**
 * @brief Ejecuta el ciclo principal de la aplicación.
 *
 * Lee los comandos ingresados desde la terminal serie,
 * separa la línea recibida en argumentos y ejecuta
 * la función asociada al comando solicitado.
 */

void loop()
{
    bool cmdOk;
    int argc;
    unsigned k;
    char line[120];
    unsigned lineLength;
    char * argv[60];

    if(appClose)
    return;


        /* Cargamos la orden                */
        if(!Serial.available())
        return;
        {
            String texto =
                Serial.readStringUntil('\n');

            texto.trim();
            texto.toCharArray(line,120);

        

        /* Separamos la orden en sus partes */
        argc = 1;

        argv[0] = line;

        lineLength = strlen(line);
      
        for(k = 0; (k < lineLength) && (argc < 60); k++){
            if(line[k] == ' '){
                line[k] = '\0';
                argv[argc] = line + k + 1;
                argc++;
            }
        }

        /* Buscamos el comando y lo ejecutamos */
        cmdOk = false;
        k = 0;
      
        while(commands[k].act){
            if(strcmp(commands[k].keyWord, argv[0]) == 0){
                cmdOk = true;

                if(commands[k].act(argc, argv))
                  Serial.printf(" [%s Fail]\n", argv[0]);
            }
            k++;
        }
        if(!cmdOk && strlen(argv[0])){
            Serial.printf("Comando inexistente\n");
        }
            Serial.print("[*]> ");
      }
    }

   /**
 * @brief Realiza la multiplicación de dos valores.
 *
 * Obtiene dos argumentos numéricos desde la línea
 * de comandos y muestra el resultado de su producto.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0 si la operación fue realizada correctamente.
 * @return -1 si la cantidad de argumentos es incorrecta.
 */
int multi(int argc, char * argv[]){
    float v1;
    float v2;
    int ret;
    if (argc == 3){
        sscanf(argv[1], "%f", &v1);
        sscanf(argv[2], "%f", &v2);
        Serial.print(v1);
        Serial.print(" * ");
        Serial.print(v2);
        Serial.print(" = ");
        Serial.println(v1 * v2);
        ret = 0;
    }
    else{
        Serial.println("Cantidad de argumentos incorrecta");
        ret = -1;
    }
    return ret;
}

/**
 * @brief Realiza la suma de dos valores.
 *
 * Obtiene dos números ingresados como argumentos
 * y muestra el resultado de la operación.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0 si la operación fue exitosa.
 * @return -1 si la cantidad de argumentos es inválida.
 */
int sumar(int argc, char * argv[]){
    float v1;
    float v2;
    int ret;
    if (argc == 3){
        sscanf(argv[1], "%f", &v1);
        sscanf(argv[2], "%f", &v2);
        Serial.print(v1);
        Serial.print(" + ");
        Serial.print(v2);
        Serial.print(" = ");
        Serial.println(v1 + v2);
        ret = 0;
    }
    else{
        Serial.println("Cantidad de argumentos incorrecta");
        ret = -1;
    }
    return ret;
}

/**
 * @brief Realiza la resta de dos valores.
 *
 * Toma dos argumentos numéricos ingresados desde
 * la terminal y muestra la diferencia obtenida.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0 si la operación fue exitosa.
 * @return -1 si la cantidad de argumentos es inválida.
 */
int restar(int argc, char * argv[]){
    float v1;
    float v2;
    int ret;
    if (argc == 3){
        sscanf(argv[1], "%f", &v1);
        sscanf(argv[2], "%f", &v2);
        Serial.print(v1);
        Serial.print(" - ");
        Serial.print(v2);
        Serial.print(" = ");
        Serial.println(v1 - v2);
        ret = 0;
    }
    else{
        Serial.println("Cantidad de argumentos incorrecta");
        ret = -1;
    }
    return ret;
}

/**
 * @brief Enciende el LED conectado al GPIO configurado.
 *
 * Establece el pin del LED en nivel lógico alto
 * e informa la acción realizada por la terminal serie.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0.
 */
int ledOn(int argc, char *argv[])
{
    digitalWrite(LED_PIN,HIGH);
    Serial.println("LED ON");

    return 0;
}

/**
 * @brief Apaga el LED conectado al GPIO configurado.
 *
 * Establece el pin del LED en nivel lógico bajo
 * e informa la acción realizada por la terminal serie.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0.
 */
int ledOff(int argc, char *argv[])
{
    digitalWrite(LED_PIN,LOW);
    Serial.println("LED OFF");
    return 0;
}

/**
 * @brief Controla el estado del LED mediante argumentos.
 *
 * Permite encender o apagar el LED utilizando los
 * parámetros "on" y "off" enviados desde la terminal.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0 si el comando es válido.
 * @return -1 si el argumento recibido es incorrecto.
 */
int led(int argc, char *argv[])
{
    if(argc!=2)
        return -1;

    if(strcmp(argv[1],"on")==0)
    {
        digitalWrite(LED_PIN,HIGH);
        Serial.println("LED ON");
    }
    else if(strcmp(argv[1],"off")==0)
    {
        digitalWrite(LED_PIN,LOW);
        Serial.println("LED OFF");
    }

    else
    {
        return -1;
    }
    return 0;
}

/**
 * @brief Genera un parpadeo del LED.
 *
 * Enciende y apaga el LED tres veces consecutivas
 * manteniendo un tiempo de 300 ms entre cambios
 * de estado.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0.
 */
int blink(int argc, char *argv[])
{
    for(int i=0;i<3;i++)
    {
        digitalWrite(LED_PIN,HIGH);
        delay(300);

        digitalWrite(LED_PIN,LOW);
        delay(300);
    }
        Serial.println("Blink realizado");
    return 0;
}

/**
 * @brief Deshabilita la ejecución del intérprete.
 *
 * Modifica la variable global de control para
 * impedir que el programa continúe procesando
 * nuevos comandos.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0.
 */
int exitCmd(int argc , char * argv[]){
    appClose = true;
    return 0;
}

/**
 * @brief Muestra la ayuda del intérprete.
 *
 * Recorre la tabla de comandos disponibles
 * e imprime por la terminal el nombre y la
 * descripción de cada uno de ellos.
 *
 * @param argc Cantidad de argumentos recibidos.
 * @param argv Vector de argumentos.
 *
 * @return 0.
 */
int help(int argc, char * argv[]){
    int k = 0;
    while(commands[k].act){
        Serial.printf("[%12s] : %s\n", commands[k].keyWord, commands[k].help);
        k++;
    }
    return 0;
}
